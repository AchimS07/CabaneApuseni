rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwnerRole() {
      return isSignedIn() && request.auth.token.role == 'owner';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasActiveSubscription() {
      return isSignedIn() && request.auth.token.subscriptionStatus == 'active';
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read/update their own profile; admins can read all
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Cabins ─────────────────────────────────────────────────────────────────
    match /cabins/{cabinId} {
      // Published cabins are public; unpublished are visible to their owner or admin
      allow read: if resource.data.published == true
        || isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      // Owners can create cabins for themselves if they have an active subscription; admins can create any
      allow create: if isAdmin()
        || (isOwnerRole() && hasActiveSubscription() && request.resource.data.ownerId == request.auth.uid);

      // Owners can update/delete only their own cabins; admins can update/delete any
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Guests read their own bookings; admins read all; owners read bookings for their cabins
      // Note: cabin ownership is enforced server-side (Admin SDK) for owner reads.
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can freely update; guests can cancel their own pending bookings
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId) && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ── Audit Logs ─────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
