# ─────────────────────────────────────────────
# Firebase Client SDK (public, safe for browser)
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────
# Firebase Admin SDK (server-only, NEVER expose)
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Newlines in private key must be replaced with \n in .env files
FIREBASE_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Session cookie
# ─────────────────────────────────────────────
# 64+ character random secret for signing session cookies
SESSION_SECRET=changeme_replace_with_64_char_random_secret_in_all_environments

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Observability (optional)
# ─────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
