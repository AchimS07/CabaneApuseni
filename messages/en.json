      "heading": "Frequently asked questions",
      "q1": {
        "question": "Can I change my plan anytime?",
        "answer": "Yes, you can upgrade or downgrade to any plan at any time from your account. Changes take effect at the beginning of the next billing cycle."
      },
      "q2": {
        "question": "Is there a long-term contract?",
        "answer": "No. All plans are monthly with no long-term commitment. You can cancel at any time."
      },
      "q3": {
        "question": "What does the owner commission mean?",
        "answer": "The commission applies to each confirmed booking through the platform. With higher plans, the percentage decreases, increasing net revenue."
      },
      "q4": {
        "question": "How does the trial period work?",
        "answer": "Paid plans can be tested for 14 days for free — no credit card required. You can cancel at any time during the trial."
      },
      "q5": {
        "question": "Are there discounts for annual payment?",
        "answer": "Yes! With annual payment you get 2 months free compared to monthly billing. Contact us for details."
      }
    },
