# ─────────────────────────────────────────────
# Firebase Client SDK (public, safe for browser)
# ─────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─────────────────────────────────────────────
# Firebase Admin SDK (server-only – NEVER expose to the browser)
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value from your service-account JSON.
# Replace literal newlines with \n so the value fits on one line.
FIREBASE_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Session cookie signing secret (server-only)
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
SESSION_SECRET=changeme_replace_with_64_char_random_secret_in_all_environments

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
